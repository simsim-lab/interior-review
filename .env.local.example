# ─── Supabase (interior-review 전용 프로젝트) ────────────────────────────
# supabase.com → 새 프로젝트 → Project Settings → API 에서 복사.
# 없으면 앱은 lib/seed.ts 의 로컬 데모 데이터로 렌더된다 (레이아웃 확인용).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 (RLS 우회 — 절대 클라이언트 노출/commit 금지). 시드·관리 스크립트용.
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 이메일 allowlist (콤마 구분). 여기 등록된 이메일로 로그인해야만 admin.
# ⚠️ 비워두면(fail-closed) 아무도 admin 이 아니다. supabase/schema.sql 의 is_admin() 배열과 동일하게 유지.
#    또한 Supabase Auth 에서 셀프 이메일 가입을 비활성(초대만) 하는 것을 권장.
ADMIN_EMAILS=you@example.com

# 로컬 개발 시 체크리스트 페이지를 로그인 없이 미리 보려면 1 (production 에서는 무시됨).
NEXT_PUBLIC_ADMIN_DEV_BYPASS=0
